# === xAI Grok ===
# Required.
XAI_API_KEY=xai-...

# Optional: override base URL (default: https://api.x.ai/v1)
# XAI_API_BASE=https://api.x.ai/v1

# Model selection.
GROK_MODEL=grok-4.20-reasoning   # deep analysis (single-ticker /api/copilot) — required for x_search
GROK_MODEL_FAST=grok-3-mini      # batch scoring (/api/sentiment/batch, /api/daily/scan)

# === Webhook alerts ===
# Slack incoming webhook URL or Discord webhook URL (both accept the same payload).
# Leave unset to disable alerts entirely.
# ALERT_WEBHOOK_URL=https://hooks.slack.com/services/...

# Sentiment crossing thresholds (defaults shown).
# BULLISH_THRESHOLD=0.5
# BEARISH_THRESHOLD=-0.5

# === Persistence ===
# Override the JSON store path (default: ./data/store.json).
# XBULLRADAR_STORE_PATH=/var/lib/xbullradar/store.json
